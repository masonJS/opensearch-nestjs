{
  "name": "opensearch-nestjs",
  "version": "0.1.1",
  "type": "module",
  "description": "NestJS module for OpenSearch with type-safe query builder",
  "license": "MIT",
  "private": false,
  "keywords": [
    "nestjs",
    "opensearch",
    "query-builder",
    "typescript",
    "elasticsearch"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npx tsc -p tsconfig.build.json",
    "prebuild": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opensearch-project/opensearch": ">=2.0.0",
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "reflect-metadata": ">=0.1.13"
  },
  "devDependencies": {
    "@opensearch-project/opensearch": "^3.5.1",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/testing": "^10.4.22",
    "@swc/core": "^1.15.13",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.1.13",
    "typescript": "^5.6.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  }
}
